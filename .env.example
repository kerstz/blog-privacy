# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Generate strong values with:  python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- Required (the app refuses to start without these) ---
SECRET_KEY=change_me
ENCRYPTION_KEY=change_me
ENCRYPTION_SALT=change_me

# --- Optional ---
# DATABASE_URL=sqlite:///blog.db
# SESSION_COOKIE_SECURE=true          # true in production (HTTPS)
# MAX_CONTENT_LENGTH=12582912

# --- Telegram admin bot (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
# TELEGRAM_ADMIN_USER_ID=
# TELEGRAM_ADMIN_PIN=
# TELEGRAM_ADMIN_SESSION_TTL=
# TELEGRAM_AUDIT_CHAT_ID=
